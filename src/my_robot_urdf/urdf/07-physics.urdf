<?xml version="1.0"?>
<robot name="physics">

  <!-- ========== 颜色定义 ========== -->
  <material name="blue">
    <color rgba="0 0 0.8 1"/>
  </material>
  <material name="black">
    <color rgba="0 0 0 1"/>
  </material>
  <material name="white">
    <color rgba="1 1 1 1"/>
  </material>
  <material name="red">
    <color rgba="0.8 0 0 1"/>
  </material>

  <!-- ================================================================== -->
  <!--  BASE LINK：身体                                                    -->
  <!--  新加了 <collision> 和 <inertial>                                    -->
  <!-- ================================================================== -->
  <link name="base_link">
    <!-- 外观：蓝色圆柱体 -->
    <visual>
      <geometry>
        <cylinder length="0.6" radius="0.2"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <!-- 碰撞体：和外观一样（简单圆柱体） -->
    <collision>
      <geometry>
        <cylinder length="0.6" radius="0.2"/>
      </geometry>
    </collision>
    <!-- 物理属性：质量 + 转动惯量 -->
    <inertial>
      <mass value="10"/>
      <inertia ixx="0.4" ixy="0.0" ixz="0.0"
                        iyy="0.4" iyz="0.0"
                               izz="0.2"/>
    </inertial>
  </link>

  <!-- ================================================================== -->
  <!--  LEFT LEG：左腿                                                     -->
  <!-- ================================================================== -->
  <link name="left_leg">
    <visual>
      <geometry>
        <box size="0.6 0.1 0.2"/>
      </geometry>
      <origin rpy="0 1.57075 0" xyz="0 0 0"/>
      <material name="white"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.6 0.1 0.2"/>
      </geometry>
      <origin rpy="0 1.57075 0" xyz="0 0 0"/>
    </collision>
    <inertial>
      <mass value="1"/>
      <inertia ixx="1e-3" ixy="0.0" ixz="0.0"
                        iyy="1e-3" iyz="0.0"
                               izz="1e-3"/>
    </inertial>
  </link>

  <!-- ================================================================== -->
  <!--  RIGHT LEG：右腿                                                    -->
  <!-- ================================================================== -->
  <link name="right_leg">
    <visual>
      <geometry>
        <box size="0.6 0.1 0.2"/>
      </geometry>
      <origin rpy="0 1.57075 0" xyz="0 0 0"/>
      <material name="white"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.6 0.1 0.2"/>
      </geometry>
      <origin rpy="0 1.57075 0" xyz="0 0 0"/>
    </collision>
    <inertial>
      <mass value="1"/>
      <inertia ixx="1e-3" ixy="0.0" ixz="0.0"
                        iyy="1e-3" iyz="0.0"
                               izz="1e-3"/>
    </inertial>
  </link>

  <!-- ================================================================== -->
  <!--  HEAD：头部                                                         -->
  <!-- ================================================================== -->
  <link name="head">
    <visual>
      <geometry>
        <sphere radius="0.2"/>
      </geometry>
      <material name="white"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.2"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="2"/>
      <inertia ixx="1e-3" ixy="0.0" ixz="0.0"
                        iyy="1e-3" iyz="0.0"
                               izz="1e-3"/>
    </inertial>
  </link>

  <!-- ================================================================== -->
  <!--  LEFT WHEEL：左轮                                                   -->
  <!-- ================================================================== -->
  <link name="left_wheel">
    <visual>
      <origin rpy="1.57075 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.1" radius="0.2"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin rpy="1.57075 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.1" radius="0.2"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="1e-3" ixy="0.0" ixz="0.0"
                        iyy="1e-3" iyz="0.0"
                               izz="1e-3"/>
    </inertial>
  </link>

  <!-- ================================================================== -->
  <!--  RIGHT WHEEL：右轮                                                  -->
  <!-- ================================================================== -->
  <link name="right_wheel">
    <visual>
      <origin rpy="1.57075 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.1" radius="0.2"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin rpy="1.57075 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.1" radius="0.2"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="1e-3" ixy="0.0" ixz="0.0"
                        iyy="1e-3" iyz="0.0"
                               izz="1e-3"/>
    </inertial>
  </link>

  <!-- ================================================================== -->
  <!--  GRIPPER POLE：夹爪伸缩杆                                           -->
  <!-- ================================================================== -->
  <link name="gripper_pole">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.2" radius="0.01"/>
      </geometry>
      <material name="red"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.2" radius="0.01"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="1e-3" ixy="0.0" ixz="0.0"
                        iyy="1e-3" iyz="0.0"
                               izz="1e-3"/>
    </inertial>
  </link>

  <!-- ================================================================== -->
  <!--  LEFT GRIPPER：左夹爪                                               -->
  <!-- ================================================================== -->
  <link name="left_gripper">
    <visual>
      <origin rpy="0 1.57075 0" xyz="0.08 0 0"/>
      <geometry>
        <box size="0.04 0.005 0.04"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin rpy="0 1.57075 0" xyz="0.08 0 0"/>
      <geometry>
        <box size="0.04 0.005 0.04"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="1e-3" ixy="0.0" ixz="0.0"
                        iyy="1e-3" iyz="0.0"
                               izz="1e-3"/>
    </inertial>
  </link>

  <!-- ================================================================== -->
  <!--  RIGHT GRIPPER：右夹爪                                              -->
  <!-- ================================================================== -->
  <link name="right_gripper">
    <visual>
      <origin rpy="0 1.57075 0" xyz="0.08 0 0"/>
      <geometry>
        <box size="0.04 0.005 0.04"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin rpy="0 1.57075 0" xyz="0.08 0 0"/>
      <geometry>
        <box size="0.04 0.005 0.04"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="1e-3" ixy="0.0" ixz="0.0"
                        iyy="1e-3" iyz="0.0"
                               izz="1e-3"/>
    </inertial>
  </link>

  <!-- ================================================================== -->
  <!--  JOINTS（关节）——和 06-flexible 完全一样，可动                       -->
  <!--  新加了 <dynamics> 摩擦力/阻尼                                       -->
  <!-- ================================================================== -->

  <!-- 身体 → 左腿（固定） -->
  <joint name="base_to_left_leg" type="fixed">
    <parent link="base_link"/>
    <child link="left_leg"/>
    <origin xyz="0 0.22 0.25"/>
  </joint>

  <!-- 身体 → 右腿（固定） -->
  <joint name="base_to_right_leg" type="fixed">
    <parent link="base_link"/>
    <child link="right_leg"/>
    <origin xyz="0 -0.22 0.25"/>
  </joint>

  <!-- 头部 → continuous（无限旋转）+ dynamics -->
  <joint name="head_swivel" type="continuous">
    <parent link="base_link"/>
    <child link="head"/>
    <axis xyz="0 0 1"/>
    <origin xyz="0 0 0.3"/>
    <dynamics damping="0.0" friction="0.0"/>
  </joint>

  <!-- 左轮 → continuous + dynamics -->
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <axis xyz="0 0 1"/>
    <origin rpy="0 0 0" xyz="0 0.22 -0.05"/>
    <dynamics damping="0.1" friction="1.0"/>
  </joint>

  <!-- 右轮 → continuous + dynamics -->
  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <axis xyz="0 0 1"/>
    <origin rpy="0 0 0" xyz="0 -0.22 -0.05"/>
    <dynamics damping="0.1" friction="1.0"/>
  </joint>

  <!-- 夹爪臂 → prismatic（伸缩）+ dynamics -->
  <joint name="gripper_extension" type="prismatic">
    <parent link="base_link"/>
    <child link="gripper_pole"/>
    <limit effort="1000.0" lower="-0.38" upper="0" velocity="0.5"/>
    <origin rpy="0 0 0" xyz="0.19 0 0.2"/>
    <dynamics damping="0.0" friction="0.0"/>
  </joint>

  <!-- 左夹爪 → revolute + dynamics -->
  <joint name="left_gripper_joint" type="revolute">
    <axis xyz="0 0 1"/>
    <limit effort="1000.0" lower="0.0" upper="0.548" velocity="0.5"/>
    <origin rpy="0 0 0" xyz="0.2 0.01 0"/>
    <parent link="gripper_pole"/>
    <child link="left_gripper"/>
    <dynamics damping="0.0" friction="0.0"/>
  </joint>

  <!-- 右夹爪 → revolute + dynamics -->
  <joint name="right_gripper_joint" type="revolute">
    <axis xyz="0 0 1"/>
    <limit effort="1000.0" lower="-0.548" upper="0" velocity="0.5"/>
    <origin rpy="0 0 0" xyz="0.2 -0.01 0"/>
    <parent link="gripper_pole"/>
    <child link="right_gripper"/>
    <dynamics damping="0.0" friction="0.0"/>
  </joint>

</robot>
