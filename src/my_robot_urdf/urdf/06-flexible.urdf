<?xml version="1.0"?>
<robot name="flexible">

  <!-- ========== 颜色定义 ========== -->
  <material name="blue">
    <color rgba="0 0 0.8 1"/>
  </material>
  <material name="black">
    <color rgba="0 0 0 1"/>
  </material>
  <material name="white">
    <color rgba="1 1 1 1"/>
  </material>
  <material name="red">
    <color rgba="0.8 0 0 1"/>
  </material>

  <!-- ========== LINKS（部件）========== -->

  <!-- 身体 -->
  <link name="base_link">
    <visual>
      <geometry>
        <cylinder length="0.6" radius="0.2"/>
      </geometry>
      <material name="blue"/>
    </visual>
  </link>

  <!-- 左腿 -->
  <link name="left_leg">
    <visual>
      <geometry>
        <box size="0.6 0.1 0.2"/>
      </geometry>
      <origin rpy="0 1.57075 0" xyz="0 0 0"/>
      <material name="white"/>
    </visual>
  </link>

  <!-- 右腿 -->
  <link name="right_leg">
    <visual>
      <geometry>
        <box size="0.6 0.1 0.2"/>
      </geometry>
      <origin rpy="0 1.57075 0" xyz="0 0 0"/>
      <material name="white"/>
    </visual>
  </link>

  <!-- 头部（球体） -->
  <link name="head">
    <visual>
      <geometry>
        <sphere radius="0.2"/>
      </geometry>
      <material name="white"/>
    </visual>
  </link>

  <!-- 左轮 -->
  <link name="left_wheel">
    <visual>
      <origin rpy="1.57075 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.1" radius="0.2"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <!-- 右轮 -->
  <link name="right_wheel">
    <visual>
      <origin rpy="1.57075 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.1" radius="0.2"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <!-- 夹爪伸缩杆 -->
  <link name="gripper_pole">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.2" radius="0.01"/>
      </geometry>
      <material name="red"/>
    </visual>
  </link>

  <!-- 左夹爪（新增！） -->
  <link name="left_gripper">
    <visual>
      <origin rpy="0 1.57075 0" xyz="0.08 0 0"/>
      <geometry>
        <box size="0.04 0.005 0.04"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <!-- 右夹爪（新增！） -->
  <link name="right_gripper">
    <visual>
      <origin rpy="0 1.57075 0" xyz="0.08 0 0"/>
      <geometry>
        <box size="0.04 0.005 0.04"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <!-- ========== JOINTS（关节）========== -->

  <!-- 身体 → 左腿（仍然是 fixed，腿不能动） -->
  <joint name="base_to_left_leg" type="fixed">
    <parent link="base_link"/>
    <child link="left_leg"/>
    <origin xyz="0 0.22 0.25"/>
  </joint>

  <!-- 身体 → 右腿（仍然是 fixed） -->
  <joint name="base_to_right_leg" type="fixed">
    <parent link="base_link"/>
    <child link="right_leg"/>
    <origin xyz="0 -0.22 0.25"/>
  </joint>

  <!-- ===== 改动 1：头部 → continuous（无限旋转） ===== -->
  <joint name="head_swivel" type="continuous">
    <parent link="base_link"/>
    <child link="head"/>
    <axis xyz="0 0 1"/>
    <origin xyz="0 0 0.3"/>
  </joint>

  <!-- ===== 改动 2：左轮 → continuous（无限旋转） ===== -->
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <axis xyz="0 0 1"/>
    <origin rpy="0 0 0" xyz="0 0.22 -0.05"/>
  </joint>

  <!-- ===== 改动 3：右轮 → continuous（无限旋转） ===== -->
  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <axis xyz="0 0 1"/>
    <origin rpy="0 0 0" xyz="0 -0.22 -0.05"/>
  </joint>

  <!-- ===== 改动 4：夹爪臂 → prismatic（伸缩滑动） ===== -->
  <joint name="gripper_extension" type="prismatic">
    <parent link="base_link"/>
    <child link="gripper_pole"/>
    <limit effort="1000.0" lower="-0.38" upper="0" velocity="0.5"/>
    <origin rpy="0 0 0" xyz="0.19 0 0.2"/>
  </joint>

  <!-- ===== 改动 5：左夹爪 → revolute（有限旋转） ===== -->
  <joint name="left_gripper_joint" type="revolute">
    <axis xyz="0 0 1"/>
    <limit effort="1000.0" lower="0.0" upper="0.548" velocity="0.5"/>
    <origin rpy="0 0 0" xyz="0.2 0.01 0"/>
    <parent link="gripper_pole"/>
    <child link="left_gripper"/>
  </joint>

  <!-- ===== 改动 6：右夹爪 → revolute（有限旋转） ===== -->
  <joint name="right_gripper_joint" type="revolute">
    <axis xyz="0 0 1"/>
    <limit effort="1000.0" lower="-0.548" upper="0" velocity="0.5"/>
    <origin rpy="0 0 0" xyz="0.2 -0.01 0"/>
    <parent link="gripper_pole"/>
    <child link="right_gripper"/>
  </joint>

</robot>
